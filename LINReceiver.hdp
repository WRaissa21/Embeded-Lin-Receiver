[DesignChecker]
LINReceiver_lib = $HDS_PROJECT_DIR\LINReceiver_lib\designcheck
[ModelSim]
LINReceiver_lib = $HDS_PROJECT_DIR\LINReceiver_lib\modelsim
[Precision]
LINReceiver_lib = $HDS_PROJECT_DIR\LINReceiver_lib\ps
[hdl]
LINReceiver_lib = $HDS_PROJECT_DIR\LINReceiver_lib\hdl
[hds]
LINReceiver_lib = $HDS_PROJECT_DIR\LINReceiver_lib\hds
[hds_settings]
default_library = LINReceiver_lib
version = 3
[library_type]
LINReceiver_lib = regular
[shared]
others = $HDS_TEAM_HOME/shared.hdp
